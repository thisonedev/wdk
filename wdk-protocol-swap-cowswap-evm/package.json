{
  "name": "@tetherto/wdk-protocol-swap-cowswap-evm",
  "version": "1.0.0-beta.1",
  "description": "A simple package that lets @tetherto/wdk-wallet-evm and wallet-evm-erc-4337 wallet accounts interact with the Cowswap protocol.",
  "keywords": [
    "wdk",
    "protocol",
    "swap",
    "cowswap",
    "ethereum",
    "erc-4337"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "main": "src/cowswap-protocol-evm.js",
  "type": "module",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/*.test.js",
    "test:integration": "brittle tests/integration/*.js",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "^9.1.0",
    "@cowprotocol/sdk-ethers-v6-adapter": "^0.4.4",
    "@tetherto/wdk-wallet": "^1.0.0-beta.1",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.2",
    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.1",
    "bare-node-runtime": "^1.1.4",
    "ethers": "6.13.5"
  },
  "devDependencies": {
    "brittle": "^3.0.0",
    "cross-env": "10.0.0",
    "jest": "30.0.5",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/cowswap-protocol-evm.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
