# Standard BIP-39 test mnemonic -- NEVER use in production
SEED_PHRASE=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about

# EVM module -- public Sepolia RPC, no API key needed
EVM_RPC_URL=https://sepolia.drpc.org
EVM_TOKEN_CONTRACT=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06
EVM_RECIPIENT_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# EVM ERC-4337 module
ERC4337_RPC_URL=https://sepolia.drpc.org
ERC4337_BUNDLER_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_KEY
ERC4337_RECIPIENT_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
ERC4337_TOKEN_CONTRACT=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06

# Optional -- only needed for paymaster token mode examples
# ERC4337_PAYMASTER_URL=
# ERC4337_PAYMASTER_ADDRESS=
# ERC4337_PAYMASTER_TOKEN_ADDRESS=

# Solana module -- replace token mint with one that exists on your target cluster
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RECIPIENT_ADDRESS=DYw8jCTfwHNRJhhmFcbXvVDTqWMEVFBX6ZKUmG5CNSKK
SOLANA_TOKEN_MINT=So11111111111111111111111111111111111111112

# TON module -- fill in a valid testnet recipient, Jetton, and public key
TON_TONCENTER_URL=https://testnet.toncenter.com/api/v2/jsonRPC
# TON_TONCENTER_API_KEY= # Recommended to avoid public testnet rate limits
TON_RECIPIENT_ADDRESS=UQCz5ON7jjK32HnqPushubsHxgsXgeSZDZPvh8P__oqol90r
TON_JETTON_ADDRESS=EQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAM9c
TON_READONLY_PUBLIC_KEY=REPLACE_WITH_TESTNET_PUBLIC_KEY

# TRON module -- validated on Nile testnet; replace the TRC20 contract with a valid Nile token for runtime validation
TRON_PROVIDER_URL=https://nile.trongrid.io
TRON_RECIPIENT_ADDRESS=TGzz8gjYiYRqpfmDwnLxfgPuLVNmpCswVp
TRON_TRC20_CONTRACT=TVjsyZ7fYF3qLF6BQgPmTEZy1xrNNyVAAA

# Sui module -- standard testnet RPC
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_RECIPIENT_ADDRESS=0x082d099250999ab8450a9ef3a962edf9e2449e1045be32ba5a0f2c6117ff7167
SUI_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

# MCP Toolkit examples
